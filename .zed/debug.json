[
  {
    "adapter": "JavaScript",
    "label": "Debug current vitest file",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/node_modules/vitest/vitest.mjs",
    "args": ["run", "--no-file-parallelism", "$ZED_FILE"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "console": "integratedTerminal",
    "skipFiles": ["<node_internals>/**"]
  },
  {
    "adapter": "JavaScript",
    "label": "Debug all vitest tests",
    "type": "node",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/node_modules/vitest/vitest.mjs",
    "args": ["run", "--no-file-parallelism"],
    "cwd": "$ZED_WORKTREE_ROOT",
    "console": "integratedTerminal",
    "skipFiles": ["<node_internals>/**"]
  }
]
