{
  "name": "jule-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter @fettstorch/jule build",
    "test": "bun run --filter @fettstorch/jule test",
    "test:pack": "bun run scripts/verify-package.ts",
    "test:all": "bun run test && bun run test:pack",
    "format": "oxfmt",
    "lint": "oxlint",
    "check": "oxfmt && oxlint --fix"
  },
  "devDependencies": {
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.12"
  },
  "packageManager": "bun@1.3.2"
}
