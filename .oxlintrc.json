{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": "error",
    "no-explicit-any": "warn",
    "no-console": "warn",
    "prefer-const": "error",
    "prefer-template": "error",
    "no-non-null-assertion": "off"
  },
  "ignorePatterns": ["dist/**"]
}
